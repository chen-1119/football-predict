NODE_ENV=production
NODE_OPTIONS=--max-old-space-size=1536
HOST=127.0.0.1
PORT=8788

# Public website data API. Keep "/api" when Node serves frontend and API together.
PUBLIC_DATA_API_BASE=/api
PAGE_POLL_SECONDS=15

# Server-side data refresh. 300 seconds = 5 minutes.
ENABLE_SYNC_CRON=1
SYNC_INTERVAL_SECONDS=180
SNAPSHOT_RETENTION_DAYS=30
SERVER_STORE_DIR=/var/lib/football-predict
ENABLE_500_SYNC=1
ENABLE_500_DETAILS_SYNC=1
FIVE_HUNDRED_DETAILS_MAX_MATCHES=8
FIVE_HUNDRED_DETAILS_REFRESH_MINUTES=180
FIVE_HUNDRED_DETAILS_TIMEOUT_SECONDS=10
FIVE_HUNDRED_DETAILS_MAX_ERRORS=3
ENABLE_WEATHER_SYNC=1
WEATHER_PROVIDER=open-meteo
WEATHER_LOOKAHEAD_DAYS=10
WEATHER_MAX_MATCHES=32
WEATHER_TIMEOUT_SECONDS=12
ENABLE_API_FOOTBALL_SYNC=0
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
API_FOOTBALL_KEY=replace-with-api-football-key
API_FOOTBALL_MAX_CALLS_PER_SYNC=35
API_FOOTBALL_LOOKAHEAD_DAYS=7
API_FOOTBALL_INJURY_REFRESH_MINUTES=360
API_FOOTBALL_ODDS_REFRESH_MINUTES=180
API_FOOTBALL_LINEUP_REFRESH_MINUTES=20
REQUIRE_EXTERNAL_SIGNALS=1
SOURCE_MAX_AGE_MINUTES=20
SOURCE_MIN_500_ROWS=1
SOURCE_MIN_500_MAPPED=1
SOURCE_MIN_CURRENT_MATCHES=1
SOURCE_MIN_EXTERNAL_COVERAGE=0.50

# Existing Sporttery sync tuning.
SKIP_SPORTTERY_FETCH=0
# Optional mainland egress proxy for China Sporttery. Supports HTTP(S) and SOCKS proxies accepted by curl.
# Example: SPORTTERY_OUTBOUND_PROXY=http://user:password@mainland-proxy.example.com:8080
# Example: SPORTTERY_OUTBOUND_PROXY=socks5h://user:password@mainland-proxy.example.com:1080
SPORTTERY_OUTBOUND_PROXY=
MATCH_WINDOW_BACK_DAYS=365
SPORTTERY_PAGE_DEPTH=120
ODDS_HISTORY_RETENTION_DAYS=365
ODDS_HISTORY_BUCKET_MINUTES=5

# GPT relay predictions. Turn this on after filling relay settings.
ENABLE_GPT_CRON=0
GPT_INTERVAL_SECONDS=900
GPT_PREDICT_LIMIT=8
GPT_RELAY_BASE_URL=https://your-relay.example.com
GPT_RELAY_CHAT_PATH=/v1/chat/completions
GPT_RELAY_API_KEY=replace-with-relay-key
GPT_MODEL=gpt-4o-mini
GPT_TEMPERATURE=0.2

# Required in production for /api/admin/sync and /api/admin/predict.
ADMIN_TOKEN=replace-with-a-long-random-token
ALLOW_LOCAL_ADMIN=0

# Access-code gate for recommendation content. 21600 seconds = 6 hours.
ACCESS_CODE_ADMIN_TOKEN=replace-with-fixed-code-admin-token
ACCESS_CODE_TTL_SECONDS=21600
ACCESS_CODE_SECRET=replace-with-another-long-random-secret
